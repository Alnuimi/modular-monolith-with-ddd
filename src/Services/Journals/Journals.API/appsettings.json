{
  "ConnectionStrings": {
    "Database": "redis://localhost:6379"
  },
  "JwtOptions": {
    "Issuer": "Articles",
    "Audience": "Articles",
    "Secret": "this-is-a-very-strong-secret-123!",
    "ValidForInMinutes": 432000
  },
  "RabbitMqOptions": {
    "Host": "amqp://articles-mq:5672",
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "GrpcServicesOptions": {
    "Retry": {
      "Count": 3,
      "InitialDelayMs": 2000
    },
    "Services": {
      "Person": {
        "Url": "https://auth-api:8081",
        "EnableRetry": true
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
